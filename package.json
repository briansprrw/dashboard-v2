{
  "name": "dashboard-v2",
  "version": "0.0.0",
  "private": true,
  "description": "Dash2 — glanceable task dashboard (React/Vite + Hono on Cloudflare Workers).",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "tsc --build && vite build && node scripts/verify-build-output.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply DASH2_DB --local"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/briansprrw/dashboard-v2.git"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "hono": "^4.12.31",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.47.0",
    "@cloudflare/workers-types": "^5.20260723.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.114.0"
  }
}
